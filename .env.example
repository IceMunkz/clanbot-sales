# Copy this file to ".env" in the app root (next to server.js) and fill it in.
# The app loads this .env automatically on Plesk / bare Node — no need to use the
# host's env-var UI. Keep .env OUT of the web folder (not in public/).

# ── Sales server ─────────────────────────────────────────────────────────────
SALES_PORT=4000
# Public base URL of THIS sales site (used for the Steam OpenID return_to/realm).
SALES_URL=https://yoursalesdomain.com
# Domain for the optional Caddy auto-HTTPS proxy (docker compose --profile prod).
# Should match SALES_URL's host, e.g. sales.yourdomain.com
DOMAIN=sales.yourdomain.com
NODE_ENV=production
ADMIN_TOKEN=change-me-to-a-long-random-string
# Where "new order awaiting approval" notifications are sent (optional).
ADMIN_EMAIL=you@yourdomain.com
# Secret for the signed Steam sign-in cookie. Generate: openssl rand -hex 32
# Falls back to ADMIN_TOKEN if unset, but set it explicitly in production.
SALES_SESSION_SECRET=

# ── Clanbot Accounts (cross-clan login + SSO) ─────────────────────────────────
# Shared secret bot deployments use to sign roster pushes and that this server
# uses to sign SSO handoff tokens. MUST be identical to CLANBOT_ACCOUNT_SECRET
# on every bot deployment. Empty = the accounts feature is disabled (roster
# ingestion + SSO return 503). Generate: openssl rand -hex 32
CLANBOT_ACCOUNT_SECRET=
# Central account URL injected into newly provisioned deployments. Defaults to
# SALES_URL when unset.
# CLANBOT_ACCOUNT_URL=

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...          # the monthly price ID from Stripe dashboard

SUCCESS_URL=https://yoursalesdomain.com/success
CANCEL_URL=https://yoursalesdomain.com/
# Where users are sent back after opening Stripe Billing Portal
BILLING_PORTAL_RETURN_URL=https://yoursalesdomain.com/account

# ── Pelican Panel ─────────────────────────────────────────────────────────────
PELICAN_URL=https://panel.yourdomain.com
PELICAN_API_KEY=ptla_...           # Application API key — create/suspend/unsuspend servers
PELICAN_CLIENT_API_KEY=ptlc_...    # Client API key — power signals (restart). Optional but
                                   # required for the admin "Restart" button to work.
# Set to true to log intended Pelican calls instead of making them — lets you
# test the whole sales flow before a live panel/node exists.
PELICAN_DRY_RUN=false
PELICAN_EGG_ID=1                   # Egg ID from Pelican (check URL when editing egg)
PELICAN_NEST_ID=1                  # Nest ID that contains the egg
PELICAN_NODE_ID=1                  # Node the servers will be created on
PELICAN_USER_ID=1                  # Pelican user ID that will own new servers

# Ports 3006-3050 must exist as allocations on your node in Pelican.
# Add them all at once in: Nodes → your node → Allocations → add range 3006-3050
CREDENTIAL_SERVER_URL=https://yoursalesdomain.com  # Base URL (port appended per bot)
# SECURITY: this token is handed to every provisioned bot server. Use a
# fine-grained, read-only deploy token scoped to just this repo — never a broad
# personal access token — and rotate it if it has ever been committed or shared.
GIT_REPO=https://oauth2:TOKEN@github.com/you/clanbot.git

# Docker image for bot servers (leave as-is unless you have a custom image)
DOCKER_IMAGE=ghcr.io/ptero-eggs/yolks:nodejs_22

# Resource limits per server
SERVER_MEMORY_MB=1024
SERVER_DISK_MB=5120
SERVER_CPU_PCT=100

# ── SMTP (for customer emails) ────────────────────────────────────────────────
SMTP_HOST=smtp.yourdomain.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@yourdomain.com
SMTP_PASS=your-smtp-password
SMTP_FROM=ClanBot <noreply@yourdomain.com>

# ── Data ──────────────────────────────────────────────────────────────────────
SALES_DATA_DIR=./data
